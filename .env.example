# 豆包语音妙记
VOLC_APP_KEY=
VOLC_ACCESS_KEY=
VOLC_RESOURCE_ID=volc.lark.minutes

# TOS
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=
TOS_AK=
TOS_SK=
# 可选：如果你用 STS 临时凭证，填这个
TOS_STS_TOKEN=

# 上传对象前缀
TOS_OBJECT_PREFIX=audio2txt/

# 给妙记读取音频 URL 的有效期（秒）
TOS_SIGN_EXPIRES_SEC=14400

# 轮询控制
POLL_INTERVAL_SEC=30
MAX_WAIT_MIN=120
MAX_CONCURRENT_JOBS=2

# 转写完成后自动删除 TOS 临时对象
DELETE_TEMP_OBJECT=true

# 是否保存原始转写 JSON（用于排查字段/时间戳问题）
SAVE_RAW_JSON=false
